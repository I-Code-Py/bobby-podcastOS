# --- Base de données ---
# En production (docker-compose) : postgresql+psycopg://bobby:CHANGE_ME@db:5432/bobby
# En développement local sans Postgres : sqlite:///./data/app.db
DATABASE_URL=postgresql+psycopg://bobby:CHANGE_ME@db:5432/bobby
POSTGRES_USER=bobby
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=bobby

# --- Sécurité ---
# Générer avec : openssl rand -hex 32
SECRET_KEY=CHANGE_ME
# true en production (cookies envoyés uniquement en HTTPS)
SESSION_SECURE=true

# --- Connecteurs ---
# YouTube et TikTok : scraping via yt-dlp, aucune clé requise.
# Instagram : scraping via navigateur headless (Playwright).
# Délai entre deux scrapings de comptes (secondes) pour rester discret
SCRAPE_DELAY_SECONDS=5
INSTAGRAM_DELAY_SECONDS=12
# Optionnel : fichier de cookies (format Netscape) pour fiabiliser YouTube/TikTok
# en cas de blocage occasionnel. Placer le fichier dans ./data/ et référencer
# son chemin dans le conteneur, ex : /srv/app/data/cookies.txt
COOKIES_FILE=
# RECOMMANDÉ pour Instagram : token API Apify (apify.com). L'actor
# « apify/instagram-reel-scraper » liste les reels d'un profil AVEC leur nombre
# de vues, via les proxies d'Apify — donc sans cookie et sans risque de ban.
# Free tier : 5 $/mois. Récupère le token dans Settings > Integrations.
APIFY_TOKEN=
# Fenêtre temporelle du scan Instagram : on récupère tous les reels des N
# derniers jours (peu importe combien). Défaut 30 (le mois). Mettre 7 = semaine.
INSTAGRAM_SCAN_DAYS=30
# Repli optionnel si pas d'Apify : cookies.txt d'un compte Instagram CONNECTÉ
# (Instagram bloque l'accès anonyme depuis une IP datacenter). Extension
# « Get cookies.txt », fichier dans ./data/, chemin côté conteneur.
# ex : /srv/app/data/instagram_cookies.txt
INSTAGRAM_COOKIES_FILE=

# --- Planification ---
TIMEZONE=Europe/Paris
SCHEDULER_ENABLED=true

# --- Reverse proxy ---
# Nom de domaine servi par Caddy (HTTPS automatique via Let's Encrypt).
# Utilisé uniquement par docker-compose.yml (setup VPS avec Caddy).
APP_DOMAIN=payout.example.com

# --- Déploiement Plesk uniquement (docker-compose.plesk.yml) ---
# Port local auquel le reverse proxy existant enverra le trafic du domaine.
# Change-le s'il est déjà pris sur le serveur.
APP_PORT=7000
