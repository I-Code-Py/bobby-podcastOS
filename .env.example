# --- Base de données ---
# En production (docker-compose) : postgresql+psycopg://bobby:CHANGE_ME@db:5432/bobby
# En développement local sans Postgres : sqlite:///./data/app.db
DATABASE_URL=postgresql+psycopg://bobby:CHANGE_ME@db:5432/bobby
POSTGRES_USER=bobby
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=bobby

# --- Sécurité ---
# Générer avec : openssl rand -hex 32
SECRET_KEY=CHANGE_ME
# true en production (cookies envoyés uniquement en HTTPS)
SESSION_SECURE=true

# --- Connecteurs ---
# YouTube et TikTok : scraping via yt-dlp, aucune clé requise.
# Instagram : scraping via navigateur headless (Playwright), aucun compte requis.
# Délai entre deux scrapings de comptes (secondes) pour rester discret
SCRAPE_DELAY_SECONDS=5
INSTAGRAM_DELAY_SECONDS=12
# Optionnel : fichier de cookies (format Netscape) pour fiabiliser YouTube/TikTok
# en cas de blocage occasionnel. Placer le fichier dans ./data/ et référencer
# son chemin dans le conteneur, ex : /srv/app/data/cookies.txt
COOKIES_FILE=

# --- Planification ---
TIMEZONE=Europe/Paris
SCHEDULER_ENABLED=true

# --- Reverse proxy ---
# Nom de domaine servi par Caddy (HTTPS automatique via Let's Encrypt).
# Utilisé uniquement par docker-compose.yml (setup VPS avec Caddy).
APP_DOMAIN=payout.example.com

# --- Déploiement Plesk uniquement (docker-compose.plesk.yml) ---
# Port local auquel le reverse proxy existant enverra le trafic du domaine.
# Change-le s'il est déjà pris sur le serveur.
APP_PORT=7000
